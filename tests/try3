# =============================================================

def get_scenarios(markets):
    """
    Returns a list of scenario dicts.
    Each scenario describes disruptions injected into the simulation.
    'original_*' fields store values to restore after the disruption ends.
    """
    return [
        # 0. Baseline — no disruptions
        {"name": "Baseline"},

        # 1. Supplier A fails for periods 6-9
        {"name": "Supplier Failure (periods 6-9)",
         "supplier_failure": {
             "node": "Supplier_A", "start": 6, "end": 9,
             "original_restock": {"RM_1": 100}
         }},

        # 2. Demand spike of 50% across all markets in periods 8-11
        {"name": "Demand Spike +50% (periods 8-11)",
         "demand_spike": {"start": 8, "end": 11, "multiplier": 1.5}},

        # 3. Factory 1 goes offline for periods 7-9
        {"name": "Factory 1 Downtime (periods 7-9)",
         "factory_downtime": {"node": "Factory_1", "start": 7, "end": 9}},

        # 4. Return rate drops 60% in periods 5-12
        {"name": "Return Rate Drop -60% (periods 5-12)",
         "return_rate_drop": {
             "start": 5, "end": 12, "factor": 0.4,
             "original_rates": {m.name: m.return_rate.copy() for m in markets}
         }},
    ]


