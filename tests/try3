PRODUCTION_COST = {"TECH_P1": 5.0, "TECH_P2": 6.0, "TECH_R1": 3.0, "TECH_R2": 3.5}

# CO2 emissions per unit of FP produced (kg CO2/unit)
PRODUCTION_EMISSIONS = {"TECH_P1": 2.0, "TECH_P2": 2.5, "TECH_R1": 0.8, "TECH_R2": 1.0}

